# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
# Tracked: ios/ + android/ (bare native projects for EAS). Build outputs ignored in ios/.gitignore and android/.gitignore.
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# Never commit OS / IDE installers (they break GitHub's 100MB limit if dropped under public/)
public/**/*.exe
public/**/*.msi
public/**/*.dmg
public/**/*.pkg
