# Copy to .env and adjust for your machine. Expo loads EXPO_PUBLIC_* at bundle time.

EXPO_PUBLIC_ENV=DEVELOPMENT

# API base.
EXPO_PUBLIC_DEV_API_URL=http://127.0.0.1:3050
EXPO_PUBLIC_PROD_API_URL=https://your-api.example.com

# Wonder coin animation uses bundled SVGs (see wonderCoinFrames.generated.ts). After editing
# files under public/homepageimgs/Coinrotation/, run: npm run gen:coin
